# Security & Privacy: Never let AI see sensitive data
.env*
*.pem
*.key
certs/
secrets/
**/.env
**/.env.local

# Version Control
.git/
.svn/
.hg/

# OS/System files
.DS_Store
Thumbs.db
desktop.ini

# Build Artifacts & Caches
.next/
dist/
build/
out/
.turbo/
.cache/
.npm/

# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Large Assets (AI shouldn't try to "read" these)
public/images/
public/videos/
public/fonts/
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.ico
**/*.mp4
**/*.pdf

# Lock files (Too much noise for Chat/Composer context)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
